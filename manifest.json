<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Credencial Auri - Portaria Digital</title>

<style>
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #e9ecef;
    text-align: center;
    padding: 15px;
    margin: 0;
  }

  .box {
    background: white;
    padding: 25px;
    margin: 20px auto;
    max-width: 380px;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  }

  .logo-topo { width: 160px; height: auto; margin-bottom: 20px; }

  .password-container {
    position: relative;
    width: 100%;
  }

  .password-container input {
    padding-right: 45px;
  }

  .toggle-password {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    cursor: pointer;
    font-size: 20px;
    user-select: none;
    color: #546e7a;
  }

  input, button {
    padding: 14px;
    width: 100%;
    margin: 10px 0;
    border-radius: 12px;
    border: 1px solid #ccc;
    box-sizing: border-box;
    font-size: 16px;
    outline: none;
  }

  input:focus {
    border-color: #003366;
    box-shadow: 0 0 5px rgba(0, 51, 102, 0.2);
  }

  button {
    background-color: #004080; /* Azul Real Escuro */
    border: none;
    font-weight: bold;
    color: white;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.3s;
  }

  button:hover {
    background-color: #00264d;
  }

  /* ESTILO DA CREDENCIAL - AZUL ESCURECIDO */
  .credencial {
    margin-top: 5px;
    padding: 30px 20px 45px 20px;
    border-radius: 25px;
    background: #fff;
    border: 4px solid #003366; /* Azul Safira */
    box-shadow: 0 15px 40px rgba(0, 51, 102, 0.2);
    position: relative;
    overflow: hidden;
  }

  .watermark {
    position: absolute;
    top: 110px;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 250px;
    opacity: 0.08;
    z-index: 0;
    pointer-events: none;
  }

  .foto-container {
    position: relative;
    z-index: 1;
    margin-bottom: 10px;
  }

  .foto {
    width: 170px;
    height: 170px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #003366;
    background: white;
  }

  .nome-funcionario {
    margin: 10px 0 0 0;
    color: #001a33; /* Quase preto azulado */
    font-size: 24px;
    text-transform: uppercase;
    font-weight: 800;
  }

  .cargo-funcionario {
    color: #455a64;
    font-weight: bold;
    font-size: 16px;
    margin: -2px 0 10px 0;
  }

  .id-numero {
    font-size: 19px;
    color: #003366;
    font-family: 'Courier New', monospace;
    letter-spacing: 2px;
    font-weight: bold;
    margin-bottom: 15px;
    background-color: #f0f4f8; /* Fundo cinza azulado muito claro */
    padding: 6px 18px;
    border-radius: 8px;
    display: inline-block;
  }

  .logo-meio {
    width: 64px;
    height: 47px;
    margin: 15px auto 5px auto;
    display: block;
  }

  .loja-nome {
    font-size: 19px;
    color: #001a33;
    text-transform: capitalize;
    font-weight: normal;
    margin: 0;
  }

  .validade-discreta {
    position: absolute;
    bottom: 12px;
    right: 18px;
    font-size: 10px;
    color: #78909c;
    font-weight: 600;
  }

  .btn-voltar {
    margin-top: 25px;
    background: #263238;
    color: white;
    font-size: 12px;
    width: auto;
    padding: 8px 20px;
  }

  .hidden { display: none !important; }
  .erro { color: #b71c1c; font-weight: bold; margin-top: 10px; }
</style>
</head>
<body>

<div class="box" id="mainBox">
  
  <div id="formArea">
    <img src="auripaz.png" class="logo-topo" alt="Auri Autopeças" onerror="this.src='https://via.placeholder.com/150x50?text=Auri'">
    <h3>Portaria Digital</h3>
    
    <input type="tel" id="cpf" placeholder="Digite seu CPF">
    
    <div class="password-container">
      <input type="password" id="nascimento" placeholder="Digite a Senha" 
             inputmode="numeric" 
             readonly 
             onfocus="this.removeAttribute('readonly');"
             autocomplete="new-password" 
             name="campo_aleatorio_auri"
             spellcheck="false">
      <span class="toggle-password" id="eyeIcon" onclick="togglePass()">🙈</span>
    </div>

    <button id="btnBuscar" onclick="buscar()">ACESSAR CREDENCIAL</button>
  </div>

  <div id="resultado"></div>
</div>

<script>
function togglePass() {
  const input = document.getElementById("nascimento");
  const icon = document.getElementById("eyeIcon");
  if (input.type === "password") {
    input.type = "text";
    icon.innerText = "👁️"; 
  } else {
    input.type = "password";
    icon.innerText = "🙈"; 
  }
}

function buscar() {
  const formArea = document.getElementById("formArea");
  const resultadoDiv = document.getElementById("resultado");
  const btn = document.getElementById("btnBuscar");
  
  var cpf = document.getElementById("cpf").value.replace(/\D/g, '');
  var nascimento = document.getElementById("nascimento").value.replace(/\D/g, '');

  if (cpf.length < 11 || nascimento.length !== 8) {
    resultadoDiv.innerHTML = "<p class='erro'>⚠️ Dados incompletos!</p>";
    return;
  }

  btn.disabled = true;
  btn.innerText = "VERIFICANDO...";

  var url = "https://script.google.com/macros/s/AKfycbzynN5FX9nQd2F9rYa0h9GOibyJ9nNmrrmcm3EJH0TrW6VAvInBwinNGW7E1bXxuY4/exec"
            + "?cpf=" + cpf
            + "&nascimento=" + nascimento;

  fetch(url)
    .then(res => res.json())
    .then(data => {
      btn.disabled = false;
      btn.innerText = "ACESSAR CREDENCIAL";

      if (data.status === "ok") {
        formArea.classList.add("hidden");
        const fotoFinal = data.foto || 'https://cdn-icons-png.flaticon.com/512/149/149071.png';

        resultadoDiv.innerHTML = `
          <div class="credencial">
            <img src="logo1.png" class="watermark">
            <div class="foto-container">
              <img src="${fotoFinal}" class="foto">
            </div>
            <h2 class="nome-funcionario">${data.nome}</h2>
            <p class="cargo-funcionario">${data.cargo}</p>
            
            <div class="id-numero">${data.identificador}</div>
            
            <img src="logo1.png" class="logo-meio" alt="Auri Logo">
            <p class="loja-nome">${data.loja.toLowerCase()}</p>
            <div class="validade-discreta">Validade: ${data.data}</div>
            <button class="btn-voltar" onclick="window.location.reload()">SAIR / VOLTAR</button>
          </div>
        `;
      } else {
        resultadoDiv.innerHTML = "<p class='erro'>❌ Não localizado!</p>";
      }
    })
    .catch(err => {
      btn.disabled = false;
      resultadoDiv.innerHTML = "<p class='erro'>Erro de conexão.</p>";
    });
}
</script>

</body>
</html>